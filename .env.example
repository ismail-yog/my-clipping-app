# ═══════════════════════════════════════════════════════
# StreamClipper — Environment Variables
# Copy this file to .env and fill in your credentials
# ═══════════════════════════════════════════════════════

# ── Twitch API ──────────────────────────────────────────
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# ── YouTube Data API v3 ─────────────────────────────────
# Path to your OAuth 2.0 client_secrets.json file
YOUTUBE_CLIENT_SECRETS=client_secrets.json
# Token file will be auto-created after first auth
YOUTUBE_TOKEN_FILE=youtube_token.json

# ── Ollama (Local LLM — zero cost) ─────────────────────
# Make sure Ollama is running: ollama serve
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_FALLBACK_MODEL=mistral

# ── Whisper Settings ────────────────────────────────────
WHISPER_MODEL=base
# Options: tiny, base, small, medium, large-v3
# tiny=~1GB VRAM, base=~1GB, small=~2GB, medium=~5GB, large-v3=~10GB

# ── Database ────────────────────────────────────────────
# SQLite database path (default: ./streamclipper.db)
# DATABASE_PATH=streamclipper.db

# ── Dashboard ───────────────────────────────────────────
DASHBOARD_PORT=8420
DASHBOARD_HOST=0.0.0.0

# ── Task Queue ──────────────────────────────────────────
QUEUE_POLL_INTERVAL=5.0
UPLOAD_MAX_PER_DAY=6
